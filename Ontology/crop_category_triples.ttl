@prefix ag: <http://w3id.org/sawgraph/v1/ag#> .
@prefix kwgr: <http://stko-kwg.geog.ucsb.edu/lod/resource/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


#################################################################
#    Ontology
#################################################################

<http://w3id.org/sawgraph/v1/ag> rdf:type owl:Ontology ;
                                  terms:contributor "Adrita Barua"@en ;
                                  terms:created "2025-10-20" ;
                                  terms:creator "The SAWGraph Project"@en ;
                                  terms:description "This ontology supports the SAWGraph"@en ;
                                  terms:title "Ontology for USDA's CropScape Crop Categories"@en ;
                                  owl:versionInfo "1.0"@en .


#################################################################
#    Annotation Properties
#################################################################

###  http://purl.org/dc/terms/contributor
terms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
terms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
terms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty .

#################################################################
#    Classes
#################################################################

###  http://w3id.org/sawgraph/v1/ag#cropCategory
ag:cropCategory rdf:type owl:Class ;
                rdfs:label "Crop Category" .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory
ag:cropSubCategory rdf:type owl:Class ;
                   rdfs:subClassOf ag:cropCategory ;
                   rdfs:label "Crop Sub-Category" .


#################################################################
#    Individuals — Crop Categories
#################################################################
###  http://w3id.org/sawgraph/v1/ag#cropCategory.FeedCrop
ag:cropCategory.FeedCrop rdf:type owl:NamedIndividual ,
                                  ag:cropCategory ;
                         rdfs:label "Crop Category for FeedCrop"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropCategory.FiberCrop
ag:cropCategory.FiberCrop rdf:type owl:NamedIndividual ,
                                   ag:cropCategory ;
                          rdfs:label "Crop Category for FiberCrop"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropCategory.FoodCrop
ag:cropCategory.FoodCrop rdf:type owl:NamedIndividual ,
                                  ag:cropCategory ;
                         rdfs:label "Crop Category for FoodCrop"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropCategory.IndustrialCrop
ag:cropCategory.IndustrialCrop rdf:type owl:NamedIndividual ,
                                        ag:cropCategory ;
                               rdfs:label "Crop Category for IndustrialCrop"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropCategory.OilCrop
ag:cropCategory.OilCrop rdf:type owl:NamedIndividual ,
                                 ag:cropCategory ;
                        rdfs:label "Crop Category for OilCrop"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropCategory.OrnamentalCrop
ag:cropCategory.OrnamentalCrop rdf:type owl:NamedIndividual ,
                                        ag:cropCategory ;
                               rdfs:label "Crop Category for OrnamentalCrop"^^xsd:string .


#################################################################
#    Individuals — Crop Sub-Categories
#################################################################

###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.Fruit
ag:cropSubCategory.Fruit rdf:type owl:NamedIndividual ,
                                  ag:cropSubCategory ;
                         rdfs:label "Crop Sub Category for Fruit"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.FruitingVegetable
ag:cropSubCategory.FruitingVegetable rdf:type owl:NamedIndividual ,
                                             ag:cropSubCategory ;
                                     rdfs:label "Crop Sub Category for FruitingVegetable"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.Grain
ag:cropSubCategory.Grain rdf:type owl:NamedIndividual ,
                                  ag:cropSubCategory ;
                         rdfs:label "Crop Sub Category for Grain"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.LeafyVegetable
ag:cropSubCategory.LeafyVegetable rdf:type owl:NamedIndividual ,
                                          ag:cropSubCategory ;
                                  rdfs:label "Crop Sub Category for LeafyVegetable"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.LegumeOrNut
ag:cropSubCategory.LegumeOrNut rdf:type owl:NamedIndividual ,
                                        ag:cropSubCategory ;
                               rdfs:label "Crop Sub Category for LegumeOrNut"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.RootOrTuberVegetable
ag:cropSubCategory.RootOrTuberVegetable rdf:type owl:NamedIndividual ,
                                                 ag:cropSubCategory ;
                                        rdfs:label "Crop Sub Category for RootOrTuberVegetable"^^xsd:string .


###  http://w3id.org/sawgraph/v1/ag#cropSubCategory.Vegetable
ag:cropSubCategory.Vegetable rdf:type owl:NamedIndividual ,
                                      ag:cropSubCategory ;
                             rdfs:label "Crop Sub Category for Vegetable"^^xsd:string .


